uv run python scripts/find_duplication.py "$PROJECT_FOLDER" \
    --language "$LANGUAGE" \
    --construct-type "$CONSTRUCT_TYPE" \
    --min-similarity "$MIN_SIMILARITY" \
    --min-lines "$MIN_LINES" \
    --max-constructs "$MAX_CONSTRUCTS"
