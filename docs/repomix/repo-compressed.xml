  # 5. Run unit tests
  print_section "Running Unit Tests"

  if npm test > /dev/null 2>&1; then
    check_pass "Unit tests passed"
  else
    check_fail "Unit tests failed"
    echo ""
    echo "Run 'npm test' for details"
