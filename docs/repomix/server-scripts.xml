        { searchTerm: name, userId: 'uncommon-names', scheduled: true },
        {
          attempts: 3,
          backoff: { type: 'exponential', delay: 2000 },
          removeOnComplete: 100,
          removeOnFail: 50,
        },
      );
    }

    console.log(`Enqueued ${selected.length} jobs`);
    await scraperQueue.close();
  }

}

main().catch(err => {
