  // Words common in commercial property owner names
  'Asset', 'Atlas', 'Build', 'Chain', 'Class', 'Coach', 'Craft', 'Crown',
  'Depot', 'Elite', 'Equip', 'Excel', 'First', 'Fleet', 'Focus', 'Force',
